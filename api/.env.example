# Used only by the drizzle-kit CLI (db:generate/db:migrate/db:push/seed) — copy
# to api/.env (gitignored) and fill in. Separate from local.settings.json,
# which is what the Functions runtime itself reads at request time.
SQL_SERVER=pokemonresulttracker.database.windows.net
SQL_DATABASE=pokemonresulttracker
SQL_USER=sqladmin
SQL_PASSWORD=your-password-here

# Local Docker SQL Server instead of Azure? Use these instead (see README):
# SQL_SERVER=localhost
# SQL_DATABASE=pokemonresulttracker
# SQL_USER=sa
# SQL_PASSWORD=P@ssw0rd_Local_Dev
# SQL_ENCRYPT=false
