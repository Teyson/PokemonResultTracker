{
  "name": "pokemon-result-tracker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "serve": "swa start build --api-location api",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "svelte": "^5.4.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
