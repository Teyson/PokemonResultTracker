{
  "platform": {
    "apiRuntime": "node:20"
  },
  "routes": [
    { "route": "/login", "redirect": "/.auth/login/github" },
    { "route": "/logout", "redirect": "/.auth/logout" },
    { "route": "/admin", "rewrite": "/admin.html" },
    { "route": "/decks", "rewrite": "/decks.html" },
    { "route": "/leaderboard", "rewrite": "/leaderboard.html" },
    { "route": "/leagues", "rewrite": "/leagues.html" },
    { "route": "/profile", "rewrite": "/profile.html" },
    { "route": "/seasons", "rewrite": "/seasons.html" },
    { "route": "/api/nights*", "allowedRoles": ["authenticated"] },
    { "route": "/api/users*", "allowedRoles": ["authenticated"] },
    { "route": "/api/leaderboard*", "allowedRoles": ["authenticated"] },
    { "route": "/api/seasons*", "allowedRoles": ["authenticated"] },
    { "route": "/api/me", "allowedRoles": ["authenticated"] }
  ],
  "globalHeaders": {
    "cache-control": "no-store"
  }
}
