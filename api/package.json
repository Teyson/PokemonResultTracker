{
  "name": "pokemon-result-tracker-api",
  "version": "2.0.0",
  "description": "Azure Functions API for the Pokémon Result Tracker",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "start": "npm run build && func start",
    "prestart": "npm run build",
    "db:generate": "drizzle-kit generate",
    "db:wait": "node scripts/wait-for-db.mjs",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "drizzle-orm": "1.0.0-rc.4",
    "mssql": "^11.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/mssql": "^9.1.5",
    "@types/node": "^20.14.10",
    "dotenv": "^16.4.5",
    "drizzle-kit": "1.0.0-rc.4",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
